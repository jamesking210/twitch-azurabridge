# =============================================
# Twitch -> AzuraCast Bridge Example Config
# Copy this file to .env and fill in real secrets.
# DO NOT commit .env to GitHub.
# =============================================

# Twitch Developer App credentials
# Create at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=changeme
TWITCH_CLIENT_SECRET=changeme

# Priority order, lowercase.
# First live channel wins. If Jimbo and Chuck are both live, Jimbo stays live.
TWITCH_USERNAMES=jimboslicechicago,chuckthedjca
TWITCH_POLL_SECONDS=30

# AzuraCast local LAN target.
# Use your local AzuraCast host/IP here, not the VPN IP and not localhost.
AZURACAST_HOST=192.168.1.17
AZURACAST_PORT=8005

# Do NOT change AzuraCast for this version.
# Your AzuraCast screen shows the Streamer/DJ mount as /, so this bridge keeps it as /.
AZURACAST_MOUNT=/

# Output mode:
# auto = use HTTP PUT when AZURACAST_MOUNT=/, otherwise use icecast://
# This avoids ffmpeg's broken-pipe/no-mountpoint error with the root / mount.
AZURACAST_OUTPUT_MODE=auto

# AzuraCast Icecast auth mode.
# source_password matches the AzuraCast screen that says:
# Password: dj_username:dj_password OR dj_username,dj_password
# If your setup only works as username/password, change this to streamer_login.
AZURACAST_AUTH_MODE=source_password
AZURACAST_SOURCE_USER=source
AZURACAST_SOURCE_PASSWORD_SEPARATOR=:

# Per-channel AzuraCast Streamer/DJ accounts.
# Use the Streamer/DJ username from AzuraCast and the password you set there.
AZURACAST_STREAMER_JIMBOSLICECHICAGO_USERNAME=jimboslicechicago
AZURACAST_STREAMER_JIMBOSLICECHICAGO_PASSWORD=changeme

AZURACAST_STREAMER_CHUCKTHEDJCA_USERNAME=chuckthedjca
AZURACAST_STREAMER_CHUCKTHEDJCA_PASSWORD=changeme

# Streamlink / ffmpeg settings
STREAMLINK_QUALITY=audio_only
STREAMLINK_LOGLEVEL=info
FFMPEG_LOGLEVEL=warning
AUDIO_BITRATE=128k
AUDIO_SAMPLE_RATE=44100

# Safety: if ffmpeg or streamlink dies immediately, wait before retrying.
BRIDGE_BACKOFF_SECONDS=120

# Usually false. Set true only if you want title/category changes to restart the stream.
RESTART_ON_METADATA_CHANGE=false
