# ------------------------------------------------------------
# Twitch → AzuraCast Bridge
# Copy this file to .env and edit the values.
# Keep .env private. Do not upload .env to GitHub.
# ------------------------------------------------------------

# Twitch API app credentials.
# Create these in the Twitch Developer Console.
TWITCH_CLIENT_ID=changeme
TWITCH_CLIENT_SECRET=changeme

# Lowercase Twitch channel priority order.
# First live channel wins.
# If both are live, jimboslicechicago wins and chuckthedjca is ignored.
TWITCH_PRIORITY=jimboslicechicago,chuckthedjca

# How often to check Twitch.
TWITCH_POLL_SECONDS=30

# Streamlink quality. Usually best, audio_only, 720p, 480p, etc.
TWITCH_QUALITY=best

# If a higher-priority channel goes live while a lower-priority channel is playing,
# switch to the higher-priority channel.
SWITCH_TO_HIGHER_PRIORITY_WHILE_LIVE=1

# If no monitored Twitch channel is live, disconnect so AzuraCast AutoDJ can resume.
STOP_WHEN_SELECTED_CHANNEL_OFFLINE=1

# ------------------------------------------------------------
# AzuraCast / Icecast target
# ------------------------------------------------------------

AZURACAST_HOST=192.168.1.17
AZURACAST_PORT=8005

# Match the mount from your working VirtualDJ/Mixxx/AzuraCast streamer setup.
# Common AzuraCast mount is /radio.mp3, but yours may be / or something else.
AZURACAST_MOUNT=/

AZURACAST_BITRATE=192k
AZURACAST_FORMAT=mp3
AZURACAST_ICECAST_PUBLIC=0

# Audio output settings.
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=2

# ------------------------------------------------------------
# Per-channel AzuraCast streamer accounts
# Keep usernames lowercase.
# Passwords here are placeholders. Change them in .env.
# ------------------------------------------------------------

AZURACAST_USER_JIMBOSLICECHICAGO=jimbo_twitch
AZURACAST_PASSWORD_JIMBOSLICECHICAGO=changeme

AZURACAST_USER_CHUCKTHEDJCA=chuck_twitch
AZURACAST_PASSWORD_CHUCKTHEDJCA=changeme

# ------------------------------------------------------------
# Metadata
# Available fields:
# {login}, {display_name}, {category}, {title}, {tags}
# ------------------------------------------------------------

METADATA_TEMPLATE={display_name} is On Twitch Live - {category} - {title}
METADATA_MAX_LENGTH=180

# FFmpeg logging: quiet, panic, fatal, error, warning, info, verbose, debug
FFMPEG_LOGLEVEL=warning
